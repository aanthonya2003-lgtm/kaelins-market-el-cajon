# Add these in Vercel Dashboard > Project > Settings > Environment Variables
# DO NOT commit real values

# Required for Vercel cron job authorization (generate: openssl rand -hex 32)
CRON_SECRET=

# Public URL of the deployment (used by cron self-fetch)
NEXT_PUBLIC_URL=https://kaelins-market-el-cajon.vercel.app

# Resend transactional email (add once owner email is verified)
# Without this, all forms remain phone CTAs per Iron Law #1
RESEND_API_KEY=
RESEND_TO_EMAIL=

# Instagram Graph API (add once @kaelinsmarket handle confirmed)
INSTAGRAM_ACCESS_TOKEN=

# Facebook Page API (add once page vanity URL confirmed)
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=
